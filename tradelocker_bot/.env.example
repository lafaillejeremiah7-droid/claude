# TradeLocker Credentials
TL_EMAIL=your_email@example.com
TL_PASSWORD=your_tradelocker_password
TL_SERVER=AQUA
TL_ENVIRONMENT=live

# Risk Settings
# RISK_PERCENT is the fallback fixed risk % (used only when no confidence
# score is available). Live/paper trades are sized with confidence-scaled risk
# between MIN_RISK_PERCENT and MAX_RISK_PERCENT.
RISK_PERCENT=2.0
MIN_RISK_PERCENT=1.0
MAX_RISK_PERCENT=3.0
MAX_TRADES_PER_DAY=2
DAILY_DRAWDOWN_LIMIT=4.0
WEEKLY_DRAWDOWN_LIMIT=4.0

# Paper Trading (--dry mode)
# Starting equity for the simulated paper account. Paper trades are sized off
# paper equity (starting equity + realized paper PnL).
PAPER_STARTING_EQUITY=10000.0

# Instruments (comma-separated)
INSTRUMENTS=BTCUSD,XAUUSD

# Logging
LOG_LEVEL=INFO

# Trading Filter Overrides (for testing / immediate trading)
# Set to skip news filter: true/false
SKIP_NEWS_FILTER=false
# Override avoid_hours (empty = trade all hours, comma-separated UTC hours to skip)
# Leave unset or remove line to use adaptive engine's learned values (default [15,16,17])
# AVOID_HOURS=

# Fallback account balance (used if API can't fetch balance)
ACCOUNT_BALANCE=5000

# Real Yields Correlation Filter (XAUUSD)
# Gold's strongest macro driver is real interest rates (10Y TIPS yield, FRED
# series DFII10, ~-0.82 historical correlation with gold) -- materially
# stronger and more stable than the US Dollar Index (DXY). Fetched from
# FRED's public CSV endpoint (no API key required). Fails open (neutral) if
# unreachable and no cache exists.
REAL_YIELDS_ENABLED=true
REAL_YIELDS_CACHE_TTL_SECONDS=21600
REAL_YIELDS_LOOKBACK_DAYS=10
REAL_YIELDS_TREND_THRESHOLD=0.05
REAL_YIELDS_FULL_SCALE_CHANGE=0.30
REAL_YIELDS_MAX_CONFIDENCE_ADJUSTMENT=1.0
