# TradeLocker Credentials
TL_EMAIL=your_email@example.com
TL_PASSWORD=your_tradelocker_password
TL_SERVER=AQUA
TL_ENVIRONMENT=live

# Risk Settings
RISK_PERCENT=2.0
MAX_TRADES_PER_DAY=2
DAILY_DRAWDOWN_LIMIT=4.0
WEEKLY_DRAWDOWN_LIMIT=4.0

# Instruments (comma-separated)
INSTRUMENTS=BTCUSD,XAUUSD

# Logging
LOG_LEVEL=INFO

# Fallback account balance (used if API can't fetch balance)
ACCOUNT_BALANCE=5000
